{
  "info": {
    "name": "IT Equipment Borrowing API",
    "description": "CS367 Final Project — IT Equipment Borrowing System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" },
    { "key": "admin_token", "value": "" },
    { "key": "equipment_id", "value": "" },
    { "key": "reservation_id", "value": "" },
    { "key": "borrowing_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Has token', () => pm.expect(pm.response.json().token).to.be.a('string'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"สมชาย ใจดี\",\n  \"email\": \"somchai@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (User)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));",
            "pm.collectionVariables.set('token', json.token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"somchai@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.collectionVariables.set('admin_token', json.token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has user', () => pm.expect(pm.response.json().user).to.be.an('object'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "Login — Wrong Password (expect 401)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"wrong\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Equipment",
      "item": [
        {
          "name": "Get All Equipments",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has equipments array', () => pm.expect(pm.response.json().equipments).to.be.an('array'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/equipments",
              "query": [
                { "key": "status", "value": "available", "disabled": true },
                { "key": "page", "value": "1", "disabled": true },
                { "key": "limit", "value": "20", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Equipment by ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/equipments/{{equipment_id}}"
          }
        },
        {
          "name": "Create Equipment (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.test('Has id', () => pm.expect(json.equipment.id).to.be.a('string'));",
            "pm.collectionVariables.set('equipment_id', json.equipment.id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": "{{base_url}}/equipments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MacBook Pro 14\",\n  \"serial_number\": \"MBP-2024-001\",\n  \"description\": \"MacBook Pro M3 14 นิ้ว\"\n}"
            }
          }
        },
        {
          "name": "Update Equipment (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": "{{base_url}}/equipments/{{equipment_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"MacBook Pro M3 14 นิ้ว — อัปเดตแล้ว\"\n}"
            }
          }
        },
        {
          "name": "Create Equipment as User (expect 403)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 403', () => pm.response.to.have.status(403));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/equipments",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"iPad\",\n  \"serial_number\": \"IPAD-001\"\n}" }
          }
        },
        {
          "name": "Delete Equipment (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/equipments/{{equipment_id}}"
          }
        }
      ]
    },
    {
      "name": "Reservation",
      "item": [
        {
          "name": "Create Reservation",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.test('Status is pending', () => pm.expect(json.reservation.status).to.equal('pending'));",
            "pm.collectionVariables.set('reservation_id', json.reservation.id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/reservations",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"equipment_id\": \"{{equipment_id}}\",\n  \"borrow_date\": \"2025-07-01\",\n  \"return_date\": \"2025-07-07\"\n}"
            }
          }
        },
        {
          "name": "Get My Reservations",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Is array', () => pm.expect(pm.response.json().reservations).to.be.an('array'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/reservations/my"
          }
        }
      ]
    },
    {
      "name": "Borrowing",
      "item": [
        {
          "name": "Confirm Borrow (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.test('Status is active', () => pm.expect(json.borrowing.status).to.equal('active'));",
            "pm.collectionVariables.set('borrowing_id', json.borrowing.id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": "{{base_url}}/borrowings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservation_id\": \"{{reservation_id}}\"\n}"
            }
          }
        },
        {
          "name": "Return Equipment",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Status is returned', () => pm.expect(pm.response.json().borrowing.status).to.equal('returned'));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/borrowings/{{borrowing_id}}/return",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"คืนสภาพดี ไม่มีความเสียหาย\"\n}"
            }
          }
        },
        {
          "name": "Return Already Returned (expect 409)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 409', () => pm.response.to.have.status(409));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/borrowings/{{borrowing_id}}/return",
            "body": { "mode": "raw", "raw": "{}" }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Get Summary (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Has equipment_summary', () => pm.expect(json.equipment_summary).to.be.an('array'));",
            "pm.test('Has top_equipments', () => pm.expect(json.top_equipments).to.be.an('array'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/reports/summary"
          }
        },
        {
          "name": "Get Summary as User (expect 403)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 403', () => pm.response.to.have.status(403));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/reports/summary"
          }
        }
      ]
    }
  ]
}
